# ════════════════════════════════════════════════════════════
#  BizBot Backend Configuration
# ════════════════════════════════════════════════════════════
#
#  Copy this file to .env and fill in the values for your setup.
#  Choose ONE mode: Cloud (Groq + Supabase) or Local (Ollama + Local PG).
#


# ── MODE 1: Cloud (Default — Groq + Supabase) ──────────────

# LLM Provider: "groq" (default) or "ollama"
LLM_PROVIDER=groq

# Groq API keys — add up to 5 for rate-limit rotation (free at console.groq.com)
GROQ_API_KEY=gsk_your_key_here
# GROQ_API_KEY_ONE=gsk_...
# GROQ_API_KEY_TWO=gsk_...
# GROQ_API_KEY_THREE=gsk_...
# GROQ_API_KEY_FOUR=gsk_...

# Supabase PostgreSQL connection string
DATABASE_URL=postgresql://postgres:<password>@<host>:5432/postgres

# Vector store: "pgvector" (default) or "chromadb"
VECTOR_STORE=pgvector

# HuggingFace API key (optional, only if using remote embeddings)
# HF_API_KEY=hf_...


# ── MODE 2: Local (Ollama + Local PostgreSQL) ──────────────
#
# Uncomment the lines below and comment out the cloud settings above.
#
# LLM_PROVIDER=ollama
# OLLAMA_BASE_URL=http://localhost:11434/v1
# OLLAMA_MODEL=llama3.2:3b
#
# DATABASE_URL=postgresql://postgres:password@localhost:5432/adventureworks
#
# VECTOR_STORE=chromadb
